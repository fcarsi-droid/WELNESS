{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/trpc/:path*", "destination": "/api/trpc/[trpc]" },
    { "source": "/api/auth/callback", "destination": "/api/auth/callback" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
